# Sanity CMS — populate these after creating the project at sanity.io
NEXT_PUBLIC_SANITY_PROJECT_ID=
NEXT_PUBLIC_SANITY_DATASET=production
NEXT_PUBLIC_SANITY_API_VERSION=2025-01-01

# Read token for fetching drafts during preview mode (Sanity dashboard → API → Tokens, viewer scope)
SANITY_API_READ_TOKEN=

# Shared secret for the Sanity → /api/revalidate webhook (any random string; configure same value in Sanity dashboard webhook)
SANITY_REVALIDATE_SECRET=
